{
  "name": "hprim-tool",
  "version": "1.3.0",
  "description": "Analyseur de résultats médicaux HPRIM",
  "main": "main.js",
  "homepage": "https://github.com/yokoinc/hprimtool",
  "author": {
    "name": "HPRIM Tool Team",
    "email": "cuffel.gregory@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node --test test/*.test.js",
    "build": "electron-builder --win",
    "build-win": "electron-builder --win",
    "dist": "npm run build"
  },
  "build": {
    "appId": "com.medical.hprimtool",
    "productName": "HPRIM Tool",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "yokoinc",
      "repo": "hprimtool"
    },
    "files": [
      "main.js",
      "preload.js",
      "parser.js",
      "render.js",
      "search.js",
      "export.js",
      "rawfile.js",
      "renderer.js",
      "init.js",
      "theme-init.js",
      "index.html",
      "i18n.js",
      "icons/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icons/icon.png",
      "verifyUpdateCodeSignature": false,
      "forceCodeSigning": false,
      "fileAssociations": [
        {
          "ext": "hpr",
          "name": "HPRIM File",
          "description": "Medical test results file"
        },
        {
          "ext": "hpm",
          "name": "HPRIM File",
          "description": "Medical test results file"
        },
        {
          "ext": "hprim",
          "name": "HPRIM File",
          "description": "Medical test results file"
        },
        {
          "ext": "hpm1",
          "name": "HPRIM File",
          "description": "Medical test results file"
        },
        {
          "ext": "hpm2",
          "name": "HPRIM File",
          "description": "Medical test results file"
        },
        {
          "ext": "hpm3",
          "name": "HPRIM File",
          "description": "Medical test results file"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HPRIM Tool"
    }
  },
  "devDependencies": {
    "electron": "^42.5.2",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
